# Copy to .env (or export in your shell) and fill in.
# The provider's api_key_env in config/llm.yaml names which variable is read.
LLM_API_KEY=

# Optional extra providers (uncomment the matching provider in config/llm.yaml)
# OPENAI_API_KEY=
# OPENROUTER_API_KEY=

# Cost-cap accounting: since no model is pinned, price per million tokens is an
# assumption. Override to match the model you actually pass at call time.
# LLM_COST_PER_MTOK_INPUT=5.0
# LLM_COST_PER_MTOK_OUTPUT=15.0
